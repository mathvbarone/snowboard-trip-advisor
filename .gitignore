node_modules/
dist/
.worktrees/

# Local agent/editor state (but .claude/settings.json IS tracked — it carries
# the shared project hook config; see CLAUDE.md Enforcement Layers)
.claude/*
!.claude/settings.json

# Logs and coverage
coverage/
*.log
npm-debug.log*

# OS/editor noise
.DS_Store
.idea/
.vscode/

# Playwright MCP runtime artifacts (snapshots, console logs, screenshots)
.playwright-mcp/

# per-workspace build & coverage outputs
apps/*/dist/
apps/*/coverage/
packages/*/dist/
packages/*/coverage/
tests/integration/dist/
tests/integration/coverage/

# publishDataset transient files
data/published/.archive-counter.lock
data/published/.*.tmp.*
