#!/bin/sh
# scripts/prepare-commit-msg — auto-add a DCO Signed-off-by trailer if not
# already present from any author.
#
# Uses `git interpret-trailers` for proper trailer-block handling. That tool:
#   - inserts a blank line between the body and the trailer block when needed
#     (avoids producing a single paragraph that fails CI's trailer parser);
#   - is comment-aware (a `# Signed-off-by:` line in the comment block does
#     NOT count as an existing trailer);
#   - deduplicates via `--if-exists addIfDifferent` (a different author's
#     existing trailer is preserved; ours is added only if missing).
#
# Skip cases (per git's prepare-commit-msg hook contract, $2 is the source):
#   - merge / squash : trailers are managed by git itself
#   - commit (amend) : preserve the original commit's trailer; user can re-sign
#                      explicitly via `git commit --amend -s`
#   - template       : respect explicit user-supplied templates
#
# Empty $2 (the normal commit path) is the only case that triggers auto-sign.

case "${2:-}" in
  merge|squash|commit|template) exit 0 ;;
esac

NAME=$(git config user.name)
EMAIL=$(git config user.email)
if [ -z "$NAME" ] || [ -z "$EMAIL" ]; then
  printf '\n!!! prepare-commit-msg: ABORTING commit — user.name and/or user.email not set !!!\n' >&2
  printf '!!! Configure with:\n' >&2
  printf '!!!   git config user.name "Your Name" && git config user.email you@example.com\n' >&2
  printf '!!! Failing locally avoids the CI dco round-trip.\n\n' >&2
  exit 1
fi

git interpret-trailers \
  --in-place \
  --if-exists addIfDifferent \
  --trailer "Signed-off-by: $NAME <$EMAIL>" \
  -- "$1"
