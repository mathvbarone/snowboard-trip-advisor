#!/bin/sh
# scripts/prepare-commit-msg — auto-add a DCO Signed-off-by trailer if not
# already present from any author.
#
# Idempotent: presence-check is a substring match against `Signed-off-by:`,
# not the exact identity, so a co-authored commit (where another author's
# `-s` already added a trailer) doesn't get a duplicate trailer with the
# local identity.
#
# Skip cases (per git's prepare-commit-msg hook contract, $2 is the source):
#   - merge / squash : trailers are managed by git itself
#   - commit (amend) : preserve the original commit's trailer; user can re-sign
#                      explicitly via `git commit --amend -s`
#   - template       : respect explicit user-supplied templates
#
# Empty $2 (the normal commit path) is the only case that triggers auto-sign.

case "${2:-}" in
  merge|squash|commit|template) exit 0 ;;
esac

NAME=$(git config user.name)
EMAIL=$(git config user.email)
if [ -z "$NAME" ] || [ -z "$EMAIL" ]; then
  printf '\n!!! prepare-commit-msg: SKIPPING DCO sign-off — user.name and/or user.email not set !!!\n' >&2
  printf '!!! Configure with: git config user.name "Your Name" && git config user.email you@example.com !!!\n' >&2
  printf '!!! CI dco check will fail this commit; fix locally to avoid the round-trip !!!\n\n' >&2
  exit 0
fi

# Substring match: skip if ANY Signed-off-by trailer is already present.
# Avoids duplicating trailers on commits that already have one (e.g. co-authored).
if grep -qiE '^Signed-off-by:' "$1"; then
  exit 0
fi

printf '\nSigned-off-by: %s <%s>\n' "$NAME" "$EMAIL" >> "$1"
